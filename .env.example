# 崇岳鉴渊 — API 密钥配置
# 复制此文件为 .env 并填入真实密钥（.env 已加入 .gitignore）
# ⚠️ Render 部署需在 Dashboard → Environment 中手动添加这些变量

# 豆包 AI（火山引擎 Ark）- 用于 AI 智能助手（流式对话 + RAG 知识库检索）
# 获取方式：https://console.volcengine.com/ark → 创建推理接入点 → 获取 API Key
DOUBAO_API_KEY=your_key_here
DOUBAO_ENDPOINT_ID=your_endpoint_id_here

# 管理员初始密码（替换默认 admin123，Render 重启不会丢失）
CYJY_ADMIN_PASSWORD=your_admin_password_here

# 密码恢复密钥（用于 /api/v1/auth/forgot-password 紧急重置密码）
CYJY_RECOVERY_KEY=your_recovery_key_here

# GitHub Token（可选）- 提升 API 速率限制
# GITHUB_TOKEN=your_token_here

# JWT 密钥（可选）- 生产环境建议设置
# CYJY_SECRET_KEY=your_secret_here
